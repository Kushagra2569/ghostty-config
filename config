background-opacity = 0.75

background-blur = true

background-blur-radius = 40

theme = Catppuccin Frappe

window-height=30

window-width=110

title="Mac OS X Terminal"

window-title-font-family="Fira Code"

font-family="Fira Code"

font-size=12

font-feature=-liga

font-thicken=true

font-feature = -calt

font-feature = -dlig

adjust-cell-height = 9%

mouse-scroll-multiplier = 0.5

macos-titlebar-style = tabs

selection-invert-fg-bg = true

bold-is-bright = true

minimum-contrast = 2

cursor-style = block

cursor-style-blink = true

cursor-invert-fg-bg = true

cursor-opacity = .8

shell-integration-features = no-cursor

window-decoration = true

window-padding-x = 2

window-padding-y = 2

window-padding-balance = true

copy-on-select = clipboard

# ---keybindings using ctrl a as leader key ----

keybind = ctrl+a>f=toggle_fullscreen

keybind = ctrl+a>v=new_split:right

keybind = ctrl+a>s=new_split:down

keybind = ctrl+a>h=goto_split:left

keybind = ctrl+a>j=goto_split:down

keybind = ctrl+a>k=goto_split:up

keybind = ctrl+a>l=goto_split:right

